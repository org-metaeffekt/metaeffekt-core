#!/usr/bin/env groovy
pipeline {

    agent {
        label 'metaeffekt-asteroid'
    }

    tools {
        jdk 'ZULU17'
        maven 'MAVEN3912'
    }

    stages {
        stage('Build and Test') {
            steps {
                withMaven(maven: 'MAVEN3912') {
                    sh 'mvn -B clean install'
                }
            }
        }
    }
}
